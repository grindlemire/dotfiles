#compdef wtc

_wtc() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '1: :->branch' \
        '*: :->command' \
        && return 0

    case $state in
        branch)
            local -a branches worktrees
            # Get existing worktree branches
            worktrees=(${(f)"$(git worktree list --porcelain 2>/dev/null | awk '/^branch / {sub(/^refs\/heads\//, "", $2); print $2}')"})
            # Get all local branches
            branches=(${(f)"$(git for-each-ref --format='%(refname:short)' refs/heads/ 2>/dev/null)"})
            # Combine and dedupe
            local -a all_branches
            all_branches=("${(@u)worktrees}" "${(@u)branches}")
            _describe -t branches 'branch' all_branches && return 0
            # Also allow new branch names
            _message 'branch name (existing or new)'
            ;;
        command)
            # Complete commands after branch
            _command_names -e
            _normal
            ;;
    esac
}

_wtc "$@"
